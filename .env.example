# =============================================================
# SENTINEL AI — Deployment Secrets & Environment Overrides
# =============================================================
#
# Copy this file to .env and fill in your values.
#
# WHAT BELONGS HERE: Secrets and values that differ between
# your laptop, staging, and production. Nothing else.
#
# WHAT DOES NOT BELONG HERE: Behavioral policy, security
# thresholds, model names, and agent configuration.
# Those live in config/defaults.toml, which is committed
# to version control so changes are code-reviewed.
#
# NEVER commit your real .env file.
# =============================================================


# --- Secrets (required in production) ---

# OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT signing secret. Must be a 64-character cryptographically random hex string.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, an ephemeral key is generated — sessions reset on every restart.
JWT_SECRET_KEY=replace-this-with-a-64-char-random-hex-string


# --- Infrastructure (environment-specific) ---

# Redis connection URL. Leave commented out to use in-process fakeredis.
# fakeredis is fine for local development and reading the book.
# Use real Redis in staging/production for persistent rate limits and budgets.
# Format: redis://[:password@]host:port/db
# REDIS_URL=redis://localhost:6379/0

# Directory where ChromaDB stores its vector database files.
# Must be writable. Use an absolute path in production.
CHROMADB_PERSIST_DIR=./data/chromadb

# Path for the append-only audit log. Must be writable.
AUDIT_LOG_FILE=./logs/audit.jsonl


# --- Application (deployment-specific) ---

# Bind host. 127.0.0.1 for local dev. 0.0.0.0 inside a container.
APP_HOST=127.0.0.1
APP_PORT=8000

# Never true in production.
APP_DEBUG=false

# Allowed CORS origins. Use specific origins — never wildcard (*).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Log verbosity. DEBUG for development, INFO for production.
LOG_LEVEL=INFO

# Set false to skip OpenAI moderation when working offline without an API key.
# Must be true in production.
CONTENT_MODERATION_ENABLED=true
